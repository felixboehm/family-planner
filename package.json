{
  "name": "family-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev:client": "pnpm --filter family-planner-client dev",
    "dev:server": "pnpm --filter family-planner-server dev",
    "dev": "concurrently --names client,server -c blue,green \"pnpm run dev:client\" \"pnpm run dev:server\""
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
